recovery-pacman() {
    sudo pacman "$@"  \
    --log /dev/null   \
    --noscriptlet     \
    --dbonly          \
    --overwrite "*"   \
    --nodeps          \
    --needed
}


mkcd() {
    mkdir $1 && cd $1
}

aperture() {

    if [[ -z "$ALACRITTY_SOCKET" ]]; then
        echo "Error: not running inside Alacritty (ALACRITTY_SOCKET not set)"
        return 1
    fi

    if [[ -z "$1" ]]; then
        echo 'This functions changes alacritty opcity value\nPlease provide a value between <0, 1>'
        return 1
    fi

    local val="$1"

    # --- Validate numeric format ---
    if ! [[ "$val" =~ '^[0-9]*\.?[0-9]+$' ]]; then
        echo "Error: '$val' is not a valid number"
        return 1
    fi

    # --- Convert to float (zsh native) ---
    local -F num="$val"

    # --- Validate range ---
    if (( num < 0 || num > 1 )); then
        echo "Error: value must be between 0 and 1"
        return 1
    fi
    
    alacritty msg config window.opacity="$num"
}

# Enable/Disable switching to a window from another workspace in gnome
gswitch() {
    gsettings set org.gnome.shell.app-switcher current-workspace-only $1
}

subgrab() {
    if [[ -z $1 ]]; then 
        echo "Must provide a url as first argument"
        return
    fi
    
    if [[ -z $2 ]]; then
        echo "Must provide language code as second argument"
        return
    fi
    
    mkdir temp && cd temp
    wget --no-verbose --show-progress -O subs.zip $1
    unzip subs.zip && rm subs.zip
    subfile=""
    
    for file in *
    do
        if [[ ${file##*.} == "srt" ]]; then
            subfile=$file
            mv $file ..
        else
            rm $file
        fi
    done

    cd .. 
    rmdir temp

    echo "subfile ${subfile}"
    if [[ -z $subfile ]]; then
        echo "Coudn't find sub file (.srt)"
        return
    fi
    
    for file in *
        case ${file##*.} in
            mp4 | mkv)
                echo "found ${file}\nnaming subs with same name"
                mv $subfile ${file%.*}.$2.srt
                echo "Done"
                return
                ;;
        esac
    echo "Coudn't find video file, cleaning up..."
    rm $subfile
    return
}

# Firefox wayland compatibility
if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
    export MOZ_ENABLE_WAYLAND=1
fi
